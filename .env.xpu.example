# =============================================================================
# ACE-Step 1.5 — Sample .env optimized for Intel Arc A770 16GB
# =============================================================================
#
# Usage:
#   cp .env.xpu.example .env
#   # then edit if needed
#
# This configuration prioritizes stability and good quality on 16 GB VRAM.
# =============================================================================

# ==================== Model Settings ====================
# Fast DiT model (recommended starting point on A770)
ACESTEP_CONFIG_PATH=acestep-v15-turbo

# Language Model
# Options: acestep-5Hz-lm-0.6B | acestep-5Hz-lm-1.7B | acestep-5Hz-lm-4B
# 1.7B is the sweet spot for A770 16GB (quality vs VRAM)
# Switch to 4B only if you enable strong CPU offload and accept slower speed
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B

# Force XPU device
ACESTEP_DEVICE=xpu

# Use native PyTorch backend (vLLM is not reliable on XPU yet)
ACESTEP_LM_BACKEND=pt

# ==================== LLM Initialization ====================
# Enable the language model (needed for thinking mode, better captions, etc.)
ACESTEP_INIT_LLM=true

# Strongly recommended on 16 GB Arc cards
ACESTEP_OFFLOAD_TO_CPU=true

# ==================== Gradio / Server Settings ====================
# Listen on all interfaces so you can access from other devices on your network
GRADIO_SERVER_NAME=0.0.0.0
PORT=7860

# For API mode (when ACESTEP_MODE=api)
ACESTEP_API_HOST=0.0.0.0
ACESTEP_API_PORT=8001

# ==================== Performance / Stability ====================
# These are also set in the Docker image, but keeping them here makes them explicit
PYTORCH_DEVICE=xpu
TORCH_COMPILE_BACKEND=eager
SYCL_CACHE_PERSISTENT=1
SYCL_PI_LEVEL_ZERO_USE_IMMEDIATE_COMMANDLISTS=1
ZE_FLAT_DEVICE_HIERARCHY=COMPOSITE

# Disable tokenizers parallelism warnings
TOKENIZERS_PARALLELISM=false

# Conservative batch size for 16 GB
ACESTEP_BATCH_SIZE=1

# ==================== Optional ====================
# Uncomment if you want to force pure DiT mode (no language model) for maximum speed
# ACESTEP_INIT_LLM=false

# Uncomment and set if you want API authentication
# ACESTEP_API_KEY=sk-change-me
