# =============================================================================
# ACE-Step 1.5 — Sample .env optimized for Intel Arc A770 16GB
# =============================================================================
#
# Usage:
#   cp .env.xpu.example .env
#
# =============================================================================

# ==================== Mode ====================
# gradio-api = Gradio + --enable-api on 8001 (required by ace-step-ui)
# gradio     = Gradio UI only on 7860
# api        = pure REST API (no Gradio client)
ACESTEP_MODE=gradio-api

# ==================== Model Settings ====================
ACESTEP_CONFIG_PATH=acestep-v15-turbo
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B
ACESTEP_DEVICE=xpu
ACESTEP_LM_BACKEND=pt

# ==================== LLM Initialization ====================
ACESTEP_INIT_LLM=true
ACESTEP_OFFLOAD_TO_CPU=true

# ==================== API / Gradio ====================
ACESTEP_API_HOST=0.0.0.0
ACESTEP_API_PORT=8001
GRADIO_SERVER_NAME=0.0.0.0

# ==================== Performance / Stability ====================
PYTORCH_DEVICE=xpu
TORCH_COMPILE_BACKEND=eager
SYCL_CACHE_PERSISTENT=1
SYCL_PI_LEVEL_ZERO_USE_IMMEDIATE_COMMANDLISTS=1
ZE_FLAT_DEVICE_HIERARCHY=COMPOSITE
TOKENIZERS_PARALLELISM=false
ACESTEP_BATCH_SIZE=1
