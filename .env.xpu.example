# =============================================================================
# ACE-Step 1.5 — Sample .env optimized for Intel Arc A770 16GB
# =============================================================================
#
# Usage:
#   cp .env.xpu.example .env
#   mkdir -p datasets/uploads lora_output checkpoints
#
# =============================================================================

# ==================== Mode ====================
# gradio-api = Gradio + --enable-api on 8001 (required by ace-step-ui)
ACESTEP_MODE=gradio-api

# ==================== Model Settings ====================
ACESTEP_CONFIG_PATH=acestep-v15-turbo
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B
ACESTEP_DEVICE=xpu
ACESTEP_LM_BACKEND=pt
ACESTEP_LLM_BACKEND=pt

# ==================== LLM Initialization ====================
ACESTEP_INIT_LLM=true
ACESTEP_INIT_SERVICE=true
ACESTEP_OFFLOAD_TO_CPU=true
# Optional stability on Arc if you see NaN latents:
# ACESTEP_DTYPE=float32

# ==================== API / Gradio ====================
ACESTEP_API_HOST=0.0.0.0
ACESTEP_API_PORT=8001
GRADIO_SERVER_NAME=0.0.0.0

# ==================== Performance ====================
PYTORCH_DEVICE=xpu
TORCH_COMPILE_BACKEND=eager
SYCL_CACHE_PERSISTENT=1
SYCL_PI_LEVEL_ZERO_USE_IMMEDIATE_COMMANDLISTS=1
ZE_FLAT_DEVICE_HIERARCHY=COMPOSITE
TOKENIZERS_PARALLELISM=false
ACESTEP_BATCH_SIZE=1

# ==================== UI / Training paths ====================
# Host dirs (bind-mounted into BOTH acestep-ui and acestep-xpu):
#   ./datasets      -> /app/datasets
#   ./lora_output   -> /app/lora_output
#   ./checkpoints   -> /app/checkpoints
#
# In the Training tab use paths under /app/datasets/..., e.g.:
#   /app/datasets/my_lora_dataset.json
#   /app/datasets/uploads
#   /app/datasets/preprocessed_tensors
#   /app/lora_output
#
# Do NOT use /app/ACE-Step-1.5/... (that path is a single-machine default).

ENABLE_DOCKER_RESTART=true
XPU_CONTAINER_NAME=acestep-xpu
JWT_SECRET=ace-step-ui-local-secret-change-me
