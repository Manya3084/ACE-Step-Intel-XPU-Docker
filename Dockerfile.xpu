# =============================================================================
# ACE-Step 1.5 — Intel XPU / Arc GPU Dockerfile
# =============================================================================
#
# Optimized for Intel Arc discrete GPUs (A770 16GB, A750, A580, A380)
# and modern Intel integrated graphics with XPU support.
#
# Tested target: Intel Arc A770 16GB on Linux (including OMV / Debian-based)
#
# Build:
#   docker build -f Dockerfile.xpu -t acestep-xpu .
#
# Run (Gradio UI):
#   docker run --rm -it \
#     --device=/dev/dri \
#     -p 7860:7860 \
#     -v $(pwd)/checkpoints:/app/checkpoints \
#     -v $(pwd)/gradio_outputs:/app/gradio_outputs \
#     -e ACESTEP_MODE=gradio \
#     acestep-xpu
#
# Notes:
#   - Requires Intel GPU drivers + Level Zero on the host
#   - Pass /dev/dri (and sometimes render nodes) for GPU access
#   - For best results on A770 16GB: use turbo DiT + 1.7B or 4B LM with offload
# =============================================================================

ARG PYTHON_VERSION=3.11
ARG UV_VERSION=0.7

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# ==================== System packages + Intel GPU repository ====================
RUN apt-get update && apt-get install -y --no-install-recommends \
        software-properties-common \
        build-essential \
        git \
        curl \
        wget \
        ca-certificates \
        gnupg \
        gpg-agent \
        # Audio
        libsndfile1 \
        libsndfile1-dev \
        ffmpeg \
        # Python build deps
        libffi-dev \
        libssl-dev \
        # Useful utilities
        pciutils \
    && rm -rf /var/lib/apt/lists/*

# Add Intel GPU compute repository (required for Level Zero on Ubuntu 22.04)
RUN wget -qO - https://repositories.intel.com/gpu/intel-graphics.key | \
        gpg --yes --dearmor --output /usr/share/keyrings/intel-graphics.gpg \
    && echo "deb [arch=amd64,i386 signed-by=/usr/share/keyrings/intel-graphics.gpg] https://repositories.intel.com/gpu/ubuntu jammy unified" | \
        tee /etc/apt/sources.list.d/intel-gpu-jammy.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        # Level Zero + OpenCL (correct package names from Intel repo)
        libze1 \
        libze-intel-gpu1 \
        intel-opencl-icd \
        clinfo \
        # Optional but useful for PyTorch XPU
        libze-dev \
        intel-ocloc \
    && rm -rf /var/lib/apt/lists/*

# Python 3.11 from deadsnakes
RUN add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        python3.11 \
        python3.11-dev \
        python3.11-venv \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

# ==================== uv ====================
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# ==================== Project source ====================
WORKDIR /app
COPY . /app/

# ==================== Python environment & XPU PyTorch ====================
# Create venv and install XPU-enabled PyTorch + project deps
RUN uv venv /app/.venv --python python3.11 \
    && . /app/.venv/bin/activate \
    && uv pip install --upgrade pip \
    && uv pip install --pre torch torchaudio torchvision \
         --index-url https://download.pytorch.org/whl/nightly/xpu \
    && uv pip install -r requirements-xpu.txt \
    && uv pip install -e .

# Make sure the venv is used by default
ENV PATH="/app/.venv/bin:$PATH"
ENV VIRTUAL_ENV=/app/.venv

# ==================== Runtime directories ====================
RUN mkdir -p /app/checkpoints /app/gradio_outputs /app/output

# ==================== XPU / SYCL environment ====================
ENV PYTORCH_DEVICE=xpu
ENV TORCH_COMPILE_BACKEND=eager
ENV SYCL_CACHE_PERSISTENT=1
ENV SYCL_PI_LEVEL_ZERO_USE_IMMEDIATE_COMMANDLISTS=1
ENV ZE_FLAT_DEVICE_HIERARCHY=COMPOSITE

# Bind to all interfaces for Docker port-mapping
ENV GRADIO_SERVER_NAME=0.0.0.0
ENV ACESTEP_API_HOST=0.0.0.0

# Default mode
ENV ACESTEP_MODE=gradio
ENV ACESTEP_INIT_SERVICE=true

# Recommended defaults for A770 16GB
ENV ACESTEP_CONFIG_PATH=acestep-v15-turbo
ENV ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B
ENV ACESTEP_LLM_BACKEND=pt
ENV ACESTEP_OFFLOAD_TO_CPU=true

ENV TOKENIZERS_PARALLELISM=false

# ==================== Ports ====================
EXPOSE 7860 8001

# ==================== Health check ====================
HEALTHCHECK --interval=60s --timeout=15s --start-period=180s --retries=3 \
    CMD curl -sf http://localhost:${GRADIO_PORT:-7860}/ > /dev/null 2>&1 \
     || curl -sf http://localhost:${ACESTEP_API_PORT:-8001}/health > /dev/null 2>&1 \
     || exit 1

# ==================== Entrypoint ====================
COPY <<'ENTRYPOINT_EOF' /app/docker-entrypoint-xpu.sh
#!/usr/bin/env bash
set -e

echo "==========================================="
echo "  ACE-Step 1.5  —  Intel XPU"
echo "==========================================="
echo "Mode      : ${ACESTEP_MODE}"
echo "Python    : $(python --version 2>&1)"
echo "PyTorch   : $(python -c 'import torch; print(torch.__version__)' 2>/dev/null || echo 'N/A')"

if python -c 'import torch; assert torch.xpu.is_available()' 2>/dev/null; then
    echo "XPU       : AVAILABLE"
    python -c '
import torch
print(f"Device count: {torch.xpu.device_count()}")
for i in range(torch.xpu.device_count()):
    print(f"  [{i}] {torch.xpu.get_device_name(i)}")
' 2>/dev/null || true
else
    echo "XPU       : NOT DETECTED"
    echo "           Make sure /dev/dri is passed and Intel drivers + Level Zero are installed on the host"
fi
echo "==========================================="

INIT_ARGS=""
if [ "${ACESTEP_INIT_SERVICE:-true}" = "true" ]; then
    INIT_ARGS="--init_service true"
    [ -n "${ACESTEP_CONFIG_PATH:-}" ]   && INIT_ARGS="${INIT_ARGS} --config_path ${ACESTEP_CONFIG_PATH}"
    [ -n "${ACESTEP_LM_MODEL_PATH:-}" ] && INIT_ARGS="${INIT_ARGS} --init_llm true --lm_model_path ${ACESTEP_LM_MODEL_PATH}"
    echo "Auto-init    : DiT=${ACESTEP_CONFIG_PATH:-auto}  LM=${ACESTEP_LM_MODEL_PATH:-none}"
fi

if [ "${ACESTEP_MODE}" = "api" ]; then
    echo "Starting REST API server on 0.0.0.0:${ACESTEP_API_PORT:-8001} ..."
    exec python -m acestep.api_server \
        --host "${ACESTEP_API_HOST:-0.0.0.0}" \
        --port "${ACESTEP_API_PORT:-8001}" \
        ${ACESTEP_EXTRA_ARGS:-}
else
    echo "Starting Gradio UI on 0.0.0.0:${GRADIO_PORT:-7860} ..."
    exec python -m acestep.acestep_v15_pipeline \
        --server-name "${GRADIO_SERVER_NAME:-0.0.0.0}" \
        --port "${GRADIO_PORT:-7860}" \
        --backend "${ACESTEP_LLM_BACKEND:-pt}" \
        ${INIT_ARGS} \
        ${ACESTEP_EXTRA_ARGS:-}
fi
ENTRYPOINT_EOF

RUN chmod +x /app/docker-entrypoint-xpu.sh

ENTRYPOINT ["/app/docker-entrypoint-xpu.sh"]
