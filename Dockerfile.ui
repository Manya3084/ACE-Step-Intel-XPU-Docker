# =============================================================================
# ACE-Step UI — Docker image (fspecii/ace-step-ui)
# =============================================================================
# Frontend (Vite) on 3003, Express backend on 3001 (vite proxy).
# Host maps: 3003->3003, 3004->3001
# =============================================================================

FROM node:20-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV NODE_ENV=development

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        ca-certificates \
        curl \
        python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone ace-step-ui
RUN git clone --depth 1 https://github.com/fspecii/ace-step-ui.git .

# ---------------------------------------------------------------------------
# Patch 1: CORS — allow any origin for self-hosted LAN / mobile / Tailscale
# ---------------------------------------------------------------------------
RUN python3 - <<'PY'
from pathlib import Path
import re
p = Path("server/src/index.ts")
text = p.read_text()
new = """app.use(cors({
  // Self-hosted / Docker: allow any origin (LAN, Tailscale, hostname, mobile)
  origin: true,
  credentials: true,
}));"""
pat = re.compile(r"app\.use\(cors\(\{.*?\}\)\);", re.S)
if not pat.search(text):
    raise SystemExit("Could not find cors() block to patch")
p.write_text(pat.sub(new, text, count=1))
print("CORS patched OK")
PY

# ---------------------------------------------------------------------------
# Patch 2: buildGradioArgs — align with current ACE-Step 1.5 /generation_wrapper
# Upstream UI sends 51 args; current Gradio expects ~72 and includes sampler
# at index 26 (euler|heun). Misalignment caused:
#   Value:  is not in the list of choices: ['euler', 'heun']
# ---------------------------------------------------------------------------
RUN python3 - <<'PY'
from pathlib import Path
import re

p = Path("server/src/services/acestep.ts")
text = p.read_text()

new_fn = r'''
async function buildGradioArgs(params: GenerationParams): Promise<unknown[]> {
  // Aligned to ACE-Step 1.5 Gradio /generation_wrapper public API (~72 params).
  // Sampler MUST be "euler" or "heun" (index 26).
  const caption = params.style || 'pop music';
  const prompt = params.customMode ? caption : (params.songDescription || caption);
  const lyrics = params.instrumental ? '' : (params.lyrics || '');
  const isThinking = params.thinking ?? false;
  const isEnhance = params.enhance ?? false;
  const useCot = isEnhance || isThinking;

  const referenceAudio = await prepareAudioFile(params.referenceAudioUrl);
  const sourceAudio = await prepareAudioFile(params.sourceAudioUrl);

  const needsSource = params.taskType === 'cover' || params.taskType === 'audio2audio' || params.taskType === 'repaint';
  if (needsSource && params.sourceAudioUrl && sourceAudio === null) {
    throw new Error(`Source audio file could not be loaded from: ${params.sourceAudioUrl}.`);
  }

  return [
    // 0-19 — core generation inputs (same as older UI)
    prompt,                                                          // 0 caption
    lyrics,                                                          // 1 lyrics
    params.bpm && params.bpm > 0 ? params.bpm : 0,                    // 2 bpm
    params.keyScale || '',                                           // 3 key
    params.timeSignature || '',                                      // 4 time signature
    params.vocalLanguage || 'en',                                    // 5 language
    params.inferenceSteps ?? 8,                                      // 6 dit steps
    params.guidanceScale ?? 7.0,                                     // 7 guidance
    params.randomSeed !== false,                                     // 8 random seed
    String(params.seed ?? -1),                                       // 9 seed
    referenceAudio,                                                  // 10 ref audio
    params.duration && params.duration > 0 ? params.duration : -1,   // 11 duration
    Math.min(Math.max(params.batchSize ?? 1, 1), 16),               // 12 batch size
    sourceAudio,                                                     // 13 source audio
    params.audioCodes || '',                                         // 14 lm codes
    params.repaintingStart ?? 0.0,                                   // 15 repaint start
    params.repaintingEnd ?? -1,                                      // 16 repaint end
    params.instruction || 'Fill the audio semantic mask based on the given conditions:', // 17 instruction
    params.audioCoverStrength ?? 1.0,                                // 18 cover strength
    0.0,                                                             // 19 cover noise

    // 20-25 — flags / cfg / shift / method (task_type is not a public API arg)
    params.useAdg ?? false,                                          // 20 use ADG
    false,                                                           // 21 reserved / extra flag
    params.cfgIntervalStart ?? 0.0,                                  // 22 cfg start
    params.cfgIntervalEnd ?? 1.0,                                    // 23 cfg end
    params.shift ?? 3.0,                                             // 24 shift
    params.inferMethod || 'ode',                                     // 25 ode|sde

    // 26 — REQUIRED sampler (was missing → empty string error)
    'euler',                                                         // 26 sampler euler|heun

    // 27-33 — velocity / DCW defaults from current Gradio schema
    0.0,                                                             // 27 velocity norm threshold
    0.0,                                                             // 28 velocity ema factor
    true,                                                            // 29 dcw enabled
    'double',                                                        // 30 dcw mode
    0.02,                                                            // 31 dcw scaler
    0.06,                                                            // 32 dcw high scaler
    'haar',                                                          // 33 dcw wavelet

    // 34-37 — timesteps / audio format
    params.customTimesteps || '',                                    // 34 custom timesteps
    params.audioFormat || 'mp3',                                     // 35 format
    '128k',                                                          // 36 mp3 bitrate
    48000,                                                           // 37 sample rate

    // 38-43 — LM sampling
    params.lmTemperature ?? 0.85,                                    // 38 lm temp
    isThinking,                                                      // 39 think
    params.lmCfgScale ?? 2.0,                                        // 40 lm cfg
    params.lmTopK ?? 0,                                              // 41 lm top-k
    params.lmTopP ?? 0.9,                                            // 42 lm top-p
    params.lmNegativePrompt || 'NO USER INPUT',                      // 43 lm negative

    // 44-52 — CoT / scores / batch
    useCot ? (params.useCotMetas ?? true) : false,                   // 44 cot metas
    useCot ? (params.useCotCaption ?? false) : false,                // 45 caption rewrite
    useCot ? (params.useCotLanguage ?? true) : false,                // 46 cot language
    params.isFormatCaption ?? false,                                 // 47 format caption
    true,                                                            // 48 (schema gap fill)
    params.constrainedDecodingDebug ?? false,                        // 49 constrained debug
    params.allowLmBatch ?? true,                                     // 50 parallel thinking
    params.getScores ?? false,                                       // 51 auto score
    params.getLrc ?? false,                                          // 52 auto lrc
    params.scoreScale ?? 0.5,                                        // 53 score scale
    params.lmBatchChunkSize ?? 8,                                    // 54 lm batch chunk

    // 55-60 — track / normalization / latent
    params.trackName || null,                                        // 55 track name
    params.completeTrackClasses || [],                               // 56 track classes
    true,                                                            // 57 enable normalization
    -1.0,                                                            // 58 normalization db
    0.0,                                                             // 59 latent shift a
    0.0,                                                             // 60 latent shift b
    0.0,                                                             // 61 reserved
    1.0,                                                             // 62 latent rescale

    // 61-71 in schema (extra quality / batch controls)
    'balanced',                                                      // 63 quality mode
    0.5,                                                             // 64 quality strength
    0.0,                                                             // 65 reserved
    '',                                                              // 66 reserved string
    params.autogen ?? false,                                         // 67 autogen
    null,                                                            // 68
    null,                                                            // 69
    0.0,                                                             // 70
    1.0,                                                             // 71
    1,                                                               // 72 batch index-ish
    false,                                                           // 73 final flag
  ];
}
'''

# Replace the existing buildGradioArgs function body
pat = re.compile(
    r"async function buildGradioArgs\(params: GenerationParams\): Promise<unknown\[]> \{.*?\n\}",
    re.S,
)
m = pat.search(text)
if not m:
    raise SystemExit("Could not find buildGradioArgs function")
text = pat.sub(new_fn.strip(), text, count=1)
p.write_text(text)
print("buildGradioArgs patched OK")
PY

# Install frontend + server dependencies
RUN npm install \
    && cd server \
    && npm install \
    && cd ..

ENV PORT=3001
ENV FRONTEND_PORT=3003
ENV ACESTEP_API_URL=http://acestep-xpu:8001
ENV DATABASE_PATH=/app/data/acestep.db
ENV JWT_SECRET=ace-step-ui-local-secret-change-me
ENV FRONTEND_URL=http://localhost:3003

RUN mkdir -p /app/data /app/server/data /app/server/public/audio /app/logs \
    && chmod -R 777 /app/data /app/server/data /app/server/public/audio

EXPOSE 3003 3001

COPY <<'EOF' /app/docker-start-ui.sh
#!/usr/bin/env bash
set -e

echo "==========================================="
echo "  ACE-Step UI"
echo "==========================================="
echo "ACE-Step API : ${ACESTEP_API_URL}"
echo "Backend      : 0.0.0.0:${PORT:-3001}  (internal)"
echo "Frontend     : 0.0.0.0:${FRONTEND_PORT:-3003}"
echo "Database     : ${DATABASE_PATH}"
echo "==========================================="

mkdir -p /app/data /app/server/data /app/server/public/audio

cat > /app/server/.env <<ENVEOF
PORT=${PORT:-3001}
NODE_ENV=development
DATABASE_PATH=${DATABASE_PATH:-/app/data/acestep.db}
ACESTEP_API_URL=${ACESTEP_API_URL:-http://acestep-xpu:8001}
AUDIO_DIR=./public/audio
FRONTEND_URL=${FRONTEND_URL:-http://localhost:3003}
JWT_SECRET=${JWT_SECRET:-ace-step-ui-local-secret}
PEXELS_API_KEY=${PEXELS_API_KEY:-}
ENVEOF

cp /app/server/.env /app/.env

cd /app/server
npm run dev &
BACKEND_PID=$!

for i in $(seq 1 30); do
  if curl -sf http://127.0.0.1:${PORT:-3001}/ > /dev/null 2>&1; then
    echo "Backend is up"
    break
  fi
  sleep 1
done

cd /app
npx vite --host 0.0.0.0 --port "${FRONTEND_PORT:-3003}" &
FRONTEND_PID=$!

trap 'kill $BACKEND_PID $FRONTEND_PID 2>/dev/null; exit' INT TERM
wait
EOF

RUN chmod +x /app/docker-start-ui.sh

HEALTHCHECK --interval=30s --timeout=10s --start-period=90s --retries=5 \
    CMD curl -sf http://localhost:3003/ > /dev/null 2>&1 || curl -sf http://localhost:3001/ > /dev/null 2>&1 || exit 1

CMD ["/app/docker-start-ui.sh"]
