# =============================================================================
# ACE-Step UI — Docker image (fspecii/ace-step-ui)
# =============================================================================
# Frontend (Vite) on 3003, Express backend on 3001 (hardcoded in vite.config proxy).
# Host maps: 3003->3003, 3004->3001
# =============================================================================

FROM node:20-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV NODE_ENV=development

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone ace-step-ui
RUN git clone --depth 1 https://github.com/fspecii/ace-step-ui.git .

# ---------------------------------------------------------------------------
# Patch CORS: original only allows localhost + a few LAN ranges.
# Self-hosted users often access via hostname, Tailscale, or other IPs.
# For local Docker use, allow any origin.
# ---------------------------------------------------------------------------
RUN python3 - <<'PY'
from pathlib import Path
p = Path("server/src/index.ts")
text = p.read_text()
old = """app.use(cors({
  origin: (origin, callback) => {
    // Allow requests with no origin (mobile apps, curl, etc.)
    if (!origin) return callback(null, true);
    // Allow localhost and 127.0.0.1 on any port in development
    if (config.nodeEnv === 'development') {
      if (origin.includes('localhost') || origin.includes('127.0.0.1')) {
        return callback(null, true);
      }
      // Allow LAN IPs (192.168.x.x, 10.x.x.x, 172.16-31.x.x)
      const lanPattern = /^https?:\\/\\/(192\\.168\\.|10\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.)/;
      if (lanPattern.test(origin)) {
        return callback(null, true);
      }
    }
    // Allow configured frontend URL
    if (origin === config.frontendUrl) {
      return callback(null, true);
    }
    callback(new Error('Not allowed by CORS'));
  },
  credentials: true,
}));"""
new = """app.use(cors({
  // Self-hosted / Docker: allow any origin (LAN, Tailscale, hostname, mobile)
  origin: true,
  credentials: true,
}));"""
if old not in text:
    # Fallback: looser match — replace the whole cors({...}) block starting at origin callback
    import re
    pat = re.compile(r"app\.use\(cors\(\{.*?\}\)\);", re.S)
    m = pat.search(text)
    if not m:
        raise SystemExit("Could not find cors() block to patch")
    text = pat.sub(new.strip(), text, count=1)
else:
    text = text.replace(old, new)
p.write_text(text)
print("CORS patched OK")
PY

# Install frontend + server dependencies
RUN npm install \
    && cd server \
    && npm install \
    && cd ..

# Internal ports:
#   Express must stay on 3001 because vite.config.ts proxies /api -> 127.0.0.1:3001
#   Vite frontend on 3003
ENV PORT=3001
ENV FRONTEND_PORT=3003
ENV ACESTEP_API_URL=http://acestep-xpu:8001
ENV DATABASE_PATH=/app/data/acestep.db
ENV JWT_SECRET=ace-step-ui-local-secret-change-me
ENV FRONTEND_URL=http://localhost:3003

RUN mkdir -p /app/data /app/server/data /app/server/public/audio /app/logs \
    && chmod -R 777 /app/data /app/server/data /app/server/public/audio

EXPOSE 3003 3001

COPY <<'EOF' /app/docker-start-ui.sh
#!/usr/bin/env bash
set -e

echo "==========================================="
echo "  ACE-Step UI"
echo "==========================================="
echo "ACE-Step API : ${ACESTEP_API_URL}"
echo "Backend      : 0.0.0.0:${PORT:-3001}  (internal)"
echo "Frontend     : 0.0.0.0:${FRONTEND_PORT:-3003}"
echo "Database     : ${DATABASE_PATH}"
echo "==========================================="

mkdir -p /app/data /app/server/data /app/server/public/audio

cat > /app/server/.env <<ENVEOF
PORT=${PORT:-3001}
NODE_ENV=development
DATABASE_PATH=${DATABASE_PATH:-/app/data/acestep.db}
ACESTEP_API_URL=${ACESTEP_API_URL:-http://acestep-xpu:8001}
AUDIO_DIR=./public/audio
FRONTEND_URL=${FRONTEND_URL:-http://localhost:3003}
JWT_SECRET=${JWT_SECRET:-ace-step-ui-local-secret}
PEXELS_API_KEY=${PEXELS_API_KEY:-}
ENVEOF

cp /app/server/.env /app/.env

cd /app/server
npm run dev &
BACKEND_PID=$!

for i in $(seq 1 30); do
  if curl -sf http://127.0.0.1:${PORT:-3001}/ > /dev/null 2>&1; then
    echo "Backend is up"
    break
  fi
  sleep 1
done

cd /app
npx vite --host 0.0.0.0 --port "${FRONTEND_PORT:-3003}" &
FRONTEND_PID=$!

trap 'kill $BACKEND_PID $FRONTEND_PID 2>/dev/null; exit' INT TERM
wait
EOF

RUN chmod +x /app/docker-start-ui.sh

HEALTHCHECK --interval=30s --timeout=10s --start-period=90s --retries=5 \
    CMD curl -sf http://localhost:3003/ > /dev/null 2>&1 || curl -sf http://localhost:3001/ > /dev/null 2>&1 || exit 1

CMD ["/app/docker-start-ui.sh"]
